// SwapShelf — Prisma schema
// Hyper-local media exchange for books & board games

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  sessionToken String?  @unique
  bio          String?
  avatarUrl    String?
  latitude     Float
  longitude    Float
  zipCode      String?
  neighborhood String?
  swapScore    Int      @default(50)
  frozen       Boolean  @default(false)
  role         String   @default("USER") // USER | MODERATOR | ADMIN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items       Item[]
  loansBorrowed Loan[]  @relation("BorrowerLoans")
  loansLent   Loan[]    @relation("LenderLoans")
  messages    Message[]
  reviewsGiven Review[]  @relation("ReviewsGiven")
  reviewsReceived Review[] @relation("ReviewsReceived")
  notifications Notification[]
}

enum ItemType {
  BOOK
  BOARD_GAME
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  WORN
}

enum ItemStatus {
  AVAILABLE
  REQUESTED
  IN_TRANSIT
  BORROWED
  RETURNED
  DISPUTED
  STOLEN
  REMOVED
}

model Item {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type       ItemType
  title      String
  creator    String? // author for books, designer for games
  isbn       String? // isbn for books, upc for games
  imageUrl   String?
  condition  ItemCondition @default(GOOD)
  description String?
  status     ItemStatus @default(AVAILABLE)
  flagged    Boolean  @default(false) // true while a return is disputed or stolen
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  loans Loan[]

  // Performance indexes for discovery + filtering
  @@index([ownerId])
  @@index([status, flagged])
}

enum LoanStatus {
  REQUESTED
  ACCEPTED
  DECLINED
  MEETING_SCHEDULED
  BORROWED
  DUE_SOON
  OVERDUE
  RETURNED
  RESOLVED
  DISPUTED
  STOLEN
  CANCELLED
}

model Loan {
  id           String   @id @default(cuid())
  itemId       String
  item         Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  borrowerId   String
  borrower     User     @relation("BorrowerLoans", fields: [borrowerId], references: [id], onDelete: Restrict)
  lenderId     String
  lender       User     @relation("LenderLoans", fields: [lenderId], references: [id], onDelete: Restrict)
  status       LoanStatus @default(REQUESTED)
  startDate    DateTime?
  dueDate      DateTime?
  returnedDate DateTime?
  proposedReturnDate DateTime?
  resolvedAt   DateTime?
  moderatorId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages Message[]
  reviews Review[]
  meetup  MeetupSpot?
  extensions ExtensionRequest[]
  returnVerification ReturnVerification?

  // Performance indexes for queries + zombie-loan cron
  @@index([borrowerId])
  @@index([lenderId])
  @@index([status])
  @@index([updatedAt])
}

model Message {
  id        String   @id @default(cuid())
  loanId    String
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  senderId  String?
  sender    User?    @relation(fields: [senderId], references: [id], onDelete: SetNull)
  text      String
  systemEvent String? // e.g. "loan:accepted", "meetup:proposed"
  createdAt DateTime @default(now())

  // Performance index for chat history loading (ORDER BY createdAt)
  @@index([loanId, createdAt])
}

model MeetupSpot {
  id          String   @id @default(cuid())
  loanId      String   @unique
  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  name        String
  address     String?
  latitude    Float
  longitude   Float
  suggestedBy String
  agreedBy    String?
  status      String   @default("proposed") // proposed | agreed | updated
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id           String   @id @default(cuid())
  loanId       String
  loan         Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  reviewerId   String
  reviewer     User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Restrict)
  revieweeId   String
  reviewee     User     @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Restrict)
  rating       Int // 1-5
  punctualityScore Int // 1-5
  careScore    Int // 1-5
  comment      String?
  isRevealed   Boolean  @default(false) // hidden until both submit
  createdAt    DateTime @default(now())

  @@unique([loanId, reviewerId])
  @@index([revieweeId, isRevealed]) // Profile page review queries
  @@index([loanId, isRevealed]) // Double-blind reveal check
}

enum ExtensionStatus {
  PENDING
  APPROVED
  DECLINED
  COUNTERED
}

model ExtensionRequest {
  id              String   @id @default(cuid())
  loanId          String
  loan            Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  requestedDays   Int
  proposedDueDate DateTime
  status          ExtensionStatus @default(PENDING)
  createdById     String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([loanId])
}

enum ConditionRating {
  EXCELLENT
  GOOD
  DAMAGED
}

enum VerificationStatus {
  PASSED
  DISPUTED
}

model ReturnVerification {
  id                String   @id @default(cuid())
  loanId            String   @unique
  loan              Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  verifiedById      String
  conditionRating   ConditionRating
  missingComponents String   // JSON-encoded checklist
  notes             String?
  evidenceImageUrl  String?  // Photo evidence for disputes (data URL or CDN URL)
  status            VerificationStatus
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // LOAN_REQUEST, REQUEST_ACCEPTED, REQUEST_DECLINED, RETURN_DUE, RETURN_VERIFIED, DISPUTE_FILED, DISPUTE_RESOLVED, REVIEW_REVEALED, EXTENSION_REQUESTED, EXTENSION_APPROVED, MEETUP_PROPOSED, ITEM_STOLEN
  title     String
  message   String
  read      Boolean  @default(false)
  loanId    String?
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}
