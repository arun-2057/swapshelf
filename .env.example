# Use the pooled connection string (with -pooler in the hostname / port 6543)
# to avoid exhausting Neon connection limits in Vercel serverless environments.
# DATABASE_URL=postgres://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech:6543/DATABASE

# Chat service origin (required for Socket.io client in Next.js pages).
# Dev: http://localhost:3003  |  Prod: https://your-chat-service.onrender.com
# NEXT_PUBLIC_CHAT_SERVICE_ORIGIN=http://localhost:3003

# Backend-side origin expected by CORS in middleware (non-public).
# CHAT_SERVICE_ORIGIN=http://localhost:3003

# CRON_SECRET=your-cron-secret-here
